# ─────────────────────────────────────────────
# TBT User Web — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Backend API (tbt-admin Fastify server)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk — same Clerk instance as tbt-admin
# Get from clerk.com → your application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs for this user app
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/tbt
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/tbt

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="Tamil Business Tribe"

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
